{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "WebFetch",

      "Bash(pwd)",
      "Bash(pwd *)",
      "Bash(ls)",
      "Bash(ls *)",

      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git show)",
      "Bash(git show *)",
      "Bash(git add)",
      "Bash(git add *)",
      "Bash(git commit)",
      "Bash(git commit *)",
      "Bash(git restore --staged *)",
      "Bash(git restore *)",
      "Bash(git switch -c *)",
      "Bash(git switch *)",
      "Bash(git revert *)",
      "Bash(git stash push *)",
      "Bash(git stash apply *)",
      "Bash(git stash pop)",

      "Bash(gh pr view)",
      "Bash(gh pr view *)",

      "Bash(rg)",
      "Bash(rg *)",
      "Bash(fd)",
      "Bash(fd *)",
      "Bash(which *)",
      "Bash(type *)"
    ],
    "ask": [
      "Bash(git push)",
      "Bash(git push *)"
    ],
    "deny": [
      "Bash(rm)",
      "Bash(rm *)",
      "Bash(rmdir)",
      "Bash(rmdir *)",
      "Bash(unlink)",
      "Bash(unlink *)",
      "Bash(git clean)",
      "Bash(git clean *)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(gh pr create)",
      "Bash(gh pr create *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  }
}
